    {id:5,nama:'Netflix 7 Hari',harga:15000,hpp:10000,durasi:7,status:'aktif'},
  ]);
  DB.saveCustomers([
    {id:1,nama:'Budi Santoso',wa:'6281234567890',catatan:'VIP customer'},
