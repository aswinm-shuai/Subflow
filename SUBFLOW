    {id:4,tgl:fmtDate(new Date(today.getFullYear(),today.getMonth(),5)),custId:1,paketId:4,harga:25000,hpp:16000,profit:9000,mulai:fmtDate(new Date(today.getFullYear(),today.getMonth(),5)),expired:fmtDate(new Date(today.getFullYear(),today.getMonth(),today.getDate()+1)),statusLangganan:'aktif',statusBayar:'pending',suppId:2},
