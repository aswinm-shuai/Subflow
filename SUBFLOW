<script>
// ============ STORAGE HELPERS ============
const DB = {
  get: k => { try { return JSON.parse(localStorage.getItem('sf_'+k)||'null'); } catch{ return null; } },
  set: (k,v) => localStorage.setItem('sf_'+k, JSON.stringify(v)),
  users: () => DB.get('users') || [],
  pakets: () => DB.get('pakets') || [],
  customers: () => DB.get('customers') || [],
  suppliers: () => DB.get('suppliers') || [],
  transaksis: () => DB.get('transaksis') || [],
  biayas: () => DB.get('biayas') || [],
  session: () => DB.get('session'),
  saveUsers: v => DB.set('users', v),
  savePakets: v => DB.set('pakets', v),
  saveCustomers: v => DB.set('customers', v),
  saveSuppliers: v => DB.set('suppliers', v),
  saveTransaksis: v => DB.set('transaksis', v),
  saveBiayas: v => DB.set('biayas', v),
};

// ============ TRANSAKSI CRUD HELPERS ============
// Variabel global untuk mode edit
let currentEditId = null;

function createTransaction(data) {
  const trxs = DB.transaksis();
  const newId = trxs.length ? Math.max(...trxs.map(t => t.id)) + 1 : 1;
  trxs.push({ id: newId, ...data });
  DB.saveTransaksis(trxs);
  return newId;
}

function updateTransaction(id, data) {
  const trxs = DB.transaksis();
  const idx = trxs.findIndex(t => t.id === id);
  if (idx < 0) return false;
  trxs[idx] = { id, ...data };
  DB.saveTransaksis(trxs);
  return true;
}

function deleteTransaction(id) {
  if (!confirm('Yakin hapus transaksi ini? Data tidak bisa dikembalikan.')) return;
  DB.saveTransaksis(DB.transaksis().filter(t => t.id !== id));
  showToast('Transaksi berhasil dihapus');
  renderTransaksi();
  checkReminders();
}

// ============ AUTH ============
function hashPass(p) { let h=0; for(let i=0;i<p.length;i++){h=(h*31+p.charCodeAt(i))&0xFFFFFFFF;} return h.toString(16); }

function showAuthTab(t) {
  document.getElementById('loginForm').style.display = t==='login'?'':'none';
  document.getElementById('registerForm').style.display = t==='register'?'':'none';
  document.querySelectorAll('.auth-tab button').forEach((b,i)=>b.classList.toggle('active',(i===0&&t==='login')||(i===1&&t==='register')));
  document.getElementById('authMsg').style.display='none';
}

function showAuthMsg(msg,ok=false) {
  const el=document.getElementById('authMsg');
  el.textContent=msg; el.style.display='block'; el.style.color=ok?'var(--success)':'var(--danger)';
}

function doRegister() {
  const name=document.getElementById('regName').value.trim();
  const email=document.getElementById('regEmail').value.trim();
  const pass=document.getElementById('regPass').value;
  if(!name||!email||!pass){return showAuthMsg('Semua field wajib diisi!');}
  if(!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)){return showAuthMsg('Format email tidak valid!');}
  if(pass.length<6){return showAuthMsg('Password minimal 6 karakter!');}
  const users=DB.users();
  if(users.find(u=>u.email===email)){return showAuthMsg('Email sudah terdaftar!');}
  users.push({id:Date.now(),name,email,pass:hashPass(pass)});
  DB.saveUsers(users);
  showAuthMsg('Akun berhasil dibuat! Silakan login.',true);
  setTimeout(()=>showAuthTab('login'),1500);
}

function doLogin() {
  const email=document.getElementById('loginEmail').value.trim();
  const pass=document.getElementById('loginPass').value;
  const remember=document.getElementById('rememberMe').checked;
  if(!email||!pass){return showAuthMsg('Email & password wajib diisi!');}
  const users=DB.users();
  const user=users.find(u=>u.email===email&&u.pass===hashPass(pass));
  if(!user){return showAuthMsg('Email atau password salah!');}
  DB.set('session',{...user,remember});
  initApp(user);
}

function doLogout() { DB.set('session',null); location.reload(); }

function showForgotPass() {
  const email=prompt('Masukkan email yang terdaftar:');
  if(!email)return;
  const users=DB.users();
  const user=users.find(u=>u.email===email);
  if(!user){showToast('Email tidak ditemukan','error');return;}
  showToast('Fitur reset password: Di demo ini, password baru = "reset123"','warning');
  const idx=users.indexOf(user); users[idx].pass=hashPass('reset123');
  DB.saveUsers(users);
}

function togglePass(id) {
  const el=document.getElementById(id);
  el.type=el.type==='password'?'text':'password';
}

// ============ APP INIT ============
function initApp(user) {
  document.getElementById('auth-screen').style.display='none';
  document.getElementById('app-screen').style.display='block';
  document.getElementById('sidebarAvatar').textContent=user.name[0].toUpperCase();
  document.getElementById('sidebarName').textContent=user.name;
  document.getElementById('sidebarEmail').textContent=user.email;
  document.getElementById('profileAvatarBig').textContent=user.name[0].toUpperCase();
  document.getElementById('profileNameDisplay').textContent=user.name;
  document.getElementById('profileEmailDisplay').textContent=user.email;
  document.getElementById('editName').value=user.name;
  document.getElementById('editEmail').value=user.email;
  if(!DB.pakets().length) seedDemoData();
  updateLanggananStatus();
  checkReminders();
  loadProfilePhoto();
  showPage('dashboard');
}

function seedDemoData() {
