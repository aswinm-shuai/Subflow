    {id:1,tgl:fmtDate(new Date(today.getFullYear(),today.getMonth(),1)),custId:1,paketId:1,harga:45000,hpp:30000,profit:15000,mulai:fmtDate(new Date(today.getFullYear(),today.getMonth(),1)),expired:fmtDate(new Date(today.getFullYear(),today.getMonth(),31)),statusLangganan:'aktif',statusBayar:'lunas',suppId:1},
