// ============ PROFIT ============
let profitChartInst;
function renderProfit() {
  const filterBulan=(document.getElementById('filterProfitBulan')||{value:''}).value||new Date().toISOString().substring(0,7);
  if(document.getElementById('filterProfitBulan'))document.getElementById('filterProfitBulan').value=filterBulan;
  const trxs=DB.transaksis();const biayas=DB.biayas();
  const mTrx=trxs.filter(t=>t.tgl&&t.tgl.startsWith(filterBulan));
  const mBiaya=biayas.filter(b=>b.tgl&&b.tgl.startsWith(filterBulan));
  const totalPenjualan=mTrx.reduce((a,t)=>a+t.harga,0);
  const totalHpp=mTrx.reduce((a,t)=>a+t.hpp,0);
  const labaKotor=mTrx.reduce((a,t)=>a+t.profit,0);
  const totalBiaya=mBiaya.reduce((a,b)=>a+b.nominal,0);
  const labaBersih=labaKotor-totalBiaya;
  document.getElementById('profitStats').innerHTML=`
    <div class="stat-card"><div class="stat-card-label">Total Penjualan</div><div class="stat-card-value">${fmtRupiah(totalPenjualan)}</div></div>
    <div class="stat-card"><div class="stat-card-label">Total HPP</div><div class="stat-card-value">${fmtRupiah(totalHpp)}</div></div>
    <div class="stat-card"><div class="stat-card-label">Laba Kotor</div><div class="stat-card-value" style="color:var(--success);">${fmtRupiah(labaKotor)}</div></div>
    <div class="stat-card"><div class="stat-card-label">Biaya Operasional</div><div class="stat-card-value" style="color:var(--danger);">${fmtRupiah(totalBiaya)}</div></div>
    <div class="stat-card"><div class="stat-card-label">Laba Bersih</div><div class="stat-card-value" style="color:${labaBersih>=0?'var(--success)':'var(--danger)'};">${fmtRupiah(labaBersih)}</div></div>`;

  const months=[];const labaArr=[];const biayaArr=[];
  for(let i=5;i>=0;i--){
    const d=new Date();d.setMonth(d.getMonth()-i);
    const m=d.toISOString().substring(0,7);
    const mn=['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
    months.push(mn[d.getMonth()]);
    const mT=trxs.filter(t=>t.tgl&&t.tgl.startsWith(m));
    const mB=biayas.filter(b=>b.tgl&&b.tgl.startsWith(m));
    labaArr.push(mT.reduce((a,t)=>a+t.profit,0));
    biayaArr.push(mB.reduce((a,b)=>a+b.nominal,0));
  }
  if(profitChartInst)profitChartInst.destroy();
  profitChartInst=new Chart(document.getElementById('profitChart'),{type:'bar',data:{labels:months,datasets:[{label:'Laba Kotor',data:labaArr,backgroundColor:'rgba(16,185,129,0.2)',borderColor:'#10b981',borderWidth:2,borderRadius:6},{label:'Biaya',data:biayaArr,backgroundColor:'rgba(239,68,68,0.15)',borderColor:'#ef4444',borderWidth:2,borderRadius:6}]},options:{responsive:true,plugins:{legend:{position:'top'}},scales:{y:{beginAtZero:true,ticks:{callback:v=>'Rp '+v.toLocaleString('id-ID')}}}}});

  document.getElementById('profitDetail').innerHTML=`
    <div style="display:flex;flex-direction:column;gap:12px;">
      ${[['Total Penjualan',totalPenjualan,'var(--gray-800)'],['Total HPP',totalHpp,'var(--danger)'],['Laba Kotor',labaKotor,'var(--success)'],['Biaya Operasional',totalBiaya,'var(--danger)'],['Laba Bersih',labaBersih,labaBersih>=0?'var(--success)':'var(--danger)']].map(([l,v,c])=>`
        <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--gray-100);">
          <span style="font-size:13px;color:var(--gray-600);">${l}</span>
          <span style="font-weight:700;color:${c};">${fmtRupiah(v)}</span>
        </div>`).join('')}
    </div>`;
}

// ============ FOTO PROFIL ============
function handlePhotoUpload(event) {
  const file = event.target.files[0];
  if (!file) return;
  if (file.size > 2 * 1024 * 1024) { showToast('Ukuran foto maksimal 2MB', 'error'); return; }
  const reader = new FileReader();
  reader.onload = function(e) {
    const base64 = e.target.result;
    const session = DB.session();
    if (session) DB.set('photo_' + session.id, base64);
    applyProfilePhoto(base64);
    showToast('Foto profil berhasil diperbarui! 📸');
  };
  reader.readAsDataURL(file);
}

function applyProfilePhoto(base64) {
  const bigAvatar = document.getElementById('profileAvatarBig');
  if (bigAvatar) bigAvatar.innerHTML = `<img src="${base64}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`;
  const sideAvatar = document.getElementById('sidebarAvatar');
  if (sideAvatar) {
    sideAvatar.innerHTML = `<img src="${base64}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">`;
    sideAvatar.style.padding = '0'; sideAvatar.style.overflow = 'hidden';
  }
}

function loadProfilePhoto() {
  const session = DB.session();
  if (!session) return;
  const saved = DB.get('photo_' + session.id);
  if (saved) applyProfilePhoto(saved);
}

// ============ PROFIL ============
function saveProfile() {
  const name=document.getElementById('editName').value.trim();
  const email=document.getElementById('editEmail').value.trim();
  const pass=document.getElementById('editPass').value;
  if(!name||!email){showToast('Nama & email wajib diisi!','error');return;}
  if(!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)){showToast('Format email tidak valid!','error');return;}
  if(pass&&pass.length<6){showToast('Password minimal 6 karakter!','error');return;}
  const session=DB.session();
  const users=DB.users();
  const idx=users.findIndex(u=>u.id===session.id);
  if(idx>=0){
    users[idx].name=name;users[idx].email=email;
    if(pass)users[idx].pass=hashPass(pass);
    DB.saveUsers(users);
    DB.set('session',{...users[idx],remember:session.remember});
    document.getElementById('sidebarName').textContent=name;
    document.getElementById('sidebarEmail').textContent=email;
    document.getElementById('profileNameDisplay').textContent=name;
    document.getElementById('profileEmailDisplay').textContent=email;
    document.getElementById('editPass').value='';
    const savedPhoto = DB.get('photo_' + session.id);
    if (savedPhoto) { applyProfilePhoto(savedPhoto); }
    else {
      document.getElementById('sidebarAvatar').textContent=name[0].toUpperCase();
      document.getElementById('profileAvatarBig').innerHTML=name[0].toUpperCase();
    }
    showToast('Profil berhasil diperbarui!');
  }
}

