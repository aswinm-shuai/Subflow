      const today2=new Date();today2.setHours(0,0,0,0);const exp=new Date(t.expired);exp.setHours(0,0,0,0);
      const diff=Math.round((exp-today2)/(1000*60*60*24));
      return `<tr><td>${c?c.nama:'-'}</td><td>${p?p.nama:'-'}</td><td>${t.expired}</td><td><span class="badge-custom badge-warning">${diff} hari</span></td><td><button class="btn-topbar btn-accent" style="padding:4px 12px;font-size:12px;" onclick="doRenewal(${t.id})"><i class="bi bi-arrow-repeat"></i> Perpanjang</button></td></tr>`;
    }).join('')}</tbody></table></div>`;
  }
}

// ============ TRANSAKSI ============
function renderTransaksi() {
  const search=(document.getElementById('searchTransaksi')||{value:''}).value.toLowerCase();
  const filterBayar=(document.getElementById('filterStatusPembayaran')||{value:''}).value;
  const filterBulan=(document.getElementById('filterBulanTransaksi')||{value:''}).value;
  const trxs=DB.transaksis();const custs=DB.customers();const pks=DB.pakets();
  let filtered=trxs.filter(t=>{
    const c=custs.find(c=>c.id===t.custId);const p=pks.find(p=>p.id===t.paketId);
    const q=(c?c.nama:'')+(p?p.nama:'');
    if(search&&!q.toLowerCase().includes(search))return false;
    if(filterBayar&&t.statusBayar!==filterBayar)return false;
    if(filterBulan&&!(t.tgl&&t.tgl.startsWith(filterBulan)))return false;
    return true;
  });
  const body=document.getElementById('transaksiBody');
  if(!filtered.length){body.innerHTML='<tr><td colspan="11"><div class="empty-state"><i class="bi bi-receipt"></i>Belum ada transaksi</div></td></tr>';return;}
  body.innerHTML=filtered.sort((a,b)=>b.id-a.id).map((t,i)=>{
    const c=custs.find(c=>c.id===t.custId);const p=pks.find(p=>p.id===t.paketId);
    const today=new Date();today.setHours(0,0,0,0);const exp=new Date(t.expired);exp.setHours(0,0,0,0);
    const isReminder=t.statusLangganan==='aktif'&&(exp-today)/(1000*60*60*24)<=3;
    return `<tr class="${isReminder?'reminder-row':''}">
      <td>${i+1}</td><td>${t.tgl||''}</td>
      <td>${c?c.nama:'<span class="text-danger">?</span>'}</td>
      <td>${p?p.nama:'<span class="text-danger">?</span>'}</td>
      <td>${fmtRupiah(t.harga)}</td>
      <td style="color:var(--success);font-weight:600;">${fmtRupiah(t.profit)}</td>
      <td>${t.mulai}</td><td>${t.expired}</td>
      <td><span class="badge-custom ${t.statusLangganan==='aktif'?'badge-success':'badge-danger'}">${t.statusLangganan}</span></td>
      <td><span class="badge-custom ${t.statusBayar==='lunas'?'badge-info':'badge-warning'}">${t.statusBayar}</span></td>
      <td style="white-space:nowrap;">
        <button class="btn-topbar" style="padding:4px 8px;font-size:12px;" onclick="toggleBayar(${t.id})" title="Toggle status bayar"><i class="bi bi-arrow-left-right"></i></button>
        <button class="btn-topbar" style="padding:4px 8px;font-size:12px;" onclick="editTransaksi(${t.id})" title="Edit"><i class="bi bi-pencil"></i></button>
        <button class="btn-topbar" style="padding:4px 8px;font-size:12px;color:var(--danger);border-color:var(--danger);" onclick="deleteTransaction(${t.id})" title="Hapus"><i class="bi bi-trash"></i></button>
        ${t.statusLangganan==='aktif'?`<button class="btn-topbar btn-accent" style="padding:4px 8px;font-size:12px;" onclick="doRenewal(${t.id})" title="Perpanjang"><i class="bi bi-arrow-repeat"></i></button>`:''}
      </td></tr>`;
  }).join('');
}

function toggleBayar(id) {
  const trxs=DB.transaksis();const idx=trxs.findIndex(t=>t.id===id);
  if(idx<0)return;
  trxs[idx].statusBayar=trxs[idx].statusBayar==='lunas'?'pending':'lunas';
  DB.saveTransaksis(trxs);renderTransaksi();showToast('Status pembayaran diperbarui');
}

