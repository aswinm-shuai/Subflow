    <div class="stat-card d-flex justify-content-between align-items-start">
      <div><div class="stat-card-label">Omzet Bulan Ini</div><div class="stat-card-value">${fmtRupiah(omzetMonth)}</div><div class="stat-card-sub">${monthTrx.length} transaksi</div></div>
      <div class="stat-card-icon" style="background:#d1fae5;color:#065f46;"><i class="bi bi-graph-up"></i></div>
    </div>
    <div class="stat-card d-flex justify-content-between align-items-start">
      <div><div class="stat-card-label">Profit Bulan Ini</div><div class="stat-card-value">${fmtRupiah(profitMonth)}</div><div class="stat-card-sub">Laba kotor</div></div>
      <div class="stat-card-icon" style="background:#fef3c7;color:#92400e;"><i class="bi bi-trophy"></i></div>
    </div>
    <div class="stat-card d-flex justify-content-between align-items-start">
      <div><div class="stat-card-label">Customer Aktif</div><div class="stat-card-value">${aktif}</div><div class="stat-card-sub">Langganan aktif</div></div>
      <div class="stat-card-icon" style="background:#ede9fe;color:#6d28d9;"><i class="bi bi-people"></i></div>
    </div>`;

  const months=[];const omzetArr=[];const profArr=[];
  for(let i=5;i>=0;i--){
    const d=new Date();d.setMonth(d.getMonth()-i);
    const m=d.toISOString().substring(0,7);
    const mn=['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
    months.push(mn[d.getMonth()]+' '+d.getFullYear().toString().slice(2));
    const mt=trxs.filter(t=>t.tgl&&t.tgl.startsWith(m));
    omzetArr.push(mt.reduce((a,t)=>a+t.harga,0));
    profArr.push(mt.reduce((a,t)=>a+t.profit,0));
  }
  if(salesChartInst)salesChartInst.destroy();
  salesChartInst=new Chart(document.getElementById('salesChart'),{type:'bar',data:{labels:months,datasets:[{label:'Omzet',data:omzetArr,backgroundColor:'rgba(37,99,235,0.15)',borderColor:'#2563eb',borderWidth:2,borderRadius:6},{label:'Profit',data:profArr,backgroundColor:'rgba(16,185,129,0.15)',borderColor:'#10b981',borderWidth:2,borderRadius:6}]},options:{responsive:true,plugins:{legend:{position:'top'}},scales:{y:{beginAtZero:true,ticks:{callback:v=>'Rp '+v.toLocaleString('id-ID')}}}}});

  const pakets=DB.pakets();
  const pkgData={};
  trxs.filter(t=>t.tgl&&t.tgl.startsWith(todayMonth)).forEach(t=>{
    const p=pakets.find(pk=>pk.id===t.paketId);
    if(p){pkgData[p.nama]=(pkgData[p.nama]||0)+1;}
  });
  if(packageChartInst)packageChartInst.destroy();
  const pkNames=Object.keys(pkgData);const pkVals=Object.values(pkgData);
  packageChartInst=new Chart(document.getElementById('packageChart'),{type:'doughnut',data:{labels:pkNames.length?pkNames:['Belum ada data'],datasets:[{data:pkVals.length?pkVals:[1],backgroundColor:['#2563eb','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4'],borderWidth:0}]},options:{responsive:true,plugins:{legend:{position:'bottom'}}}});

  const expiring=trxs.filter(t=>{
    if(t.statusLangganan!=='aktif')return false;
    const today2=new Date();today2.setHours(0,0,0,0);
    const exp=new Date(t.expired);exp.setHours(0,0,0,0);
    const diff=(exp-today2)/(1000*60*60*24);
    return diff>=0&&diff<=3;
  });
  const custs=DB.customers();const pks=DB.pakets();
  if(expiring.length===0){
    document.getElementById('reminderList').innerHTML='<p style="color:var(--gray-400);font-size:13px;">Tidak ada langganan yang akan expired dalam 3 hari ke depan.</p>';
  } else {
    document.getElementById('reminderList').innerHTML=`<div class="table-wrapper"><table class="table-custom"><thead><tr><th>Customer</th><th>Paket</th><th>Expired</th><th>Sisa Hari</th><th>Aksi</th></tr></thead><tbody>
    ${expiring.map(t=>{
