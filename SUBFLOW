// ============ LAPORAN ============
let laporanChartInst,laporanPaketChartInst;

function renderLaporan() {
  const periode=(document.getElementById('filterLaporanPeriode')||{value:''}).value;
  const trxs=DB.transaksis();const custs=DB.customers();const pks=DB.pakets();
  let filtered=trxs;
  if(periode){filtered=trxs.filter(t=>t.tgl&&t.tgl.startsWith(periode));}
  const totalOmzet=filtered.reduce((a,t)=>a+t.harga,0);
  const totalProfit=filtered.reduce((a,t)=>a+t.profit,0);
  const totalHpp=filtered.reduce((a,t)=>a+t.hpp,0);
  document.getElementById('laporanStats').innerHTML=`
    <div class="stat-card"><div class="stat-card-label">Total Transaksi</div><div class="stat-card-value">${filtered.length}</div></div>
    <div class="stat-card"><div class="stat-card-label">Total Omzet</div><div class="stat-card-value">${fmtRupiah(totalOmzet)}</div></div>
    <div class="stat-card"><div class="stat-card-label">Total HPP</div><div class="stat-card-value">${fmtRupiah(totalHpp)}</div></div>
    <div class="stat-card"><div class="stat-card-label">Laba Kotor</div><div class="stat-card-value" style="color:var(--success);">${fmtRupiah(totalProfit)}</div></div>`;

  const months=[];const omzetArr=[];
  for(let i=5;i>=0;i--){
    const d=new Date();d.setMonth(d.getMonth()-i);
    const m=d.toISOString().substring(0,7);
    const mn=['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
    months.push(mn[d.getMonth()]);
    omzetArr.push(trxs.filter(t=>t.tgl&&t.tgl.startsWith(m)).reduce((a,t)=>a+t.harga,0));
  }
  if(laporanChartInst)laporanChartInst.destroy();
  laporanChartInst=new Chart(document.getElementById('laporanChart'),{type:'line',data:{labels:months,datasets:[{label:'Omzet',data:omzetArr,borderColor:'#2563eb',backgroundColor:'rgba(37,99,235,0.06)',fill:true,tension:0.4,pointBackgroundColor:'#2563eb'}]},options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{beginAtZero:true,ticks:{callback:v=>'Rp '+v.toLocaleString('id-ID')}}}}});

  const pkgData={};
  filtered.forEach(t=>{const p=pks.find(p=>p.id===t.paketId);if(p)pkgData[p.nama]=(pkgData[p.nama]||0)+1;});
  if(laporanPaketChartInst)laporanPaketChartInst.destroy();
  const pkNames=Object.keys(pkgData);const pkVals=Object.values(pkgData);
  laporanPaketChartInst=new Chart(document.getElementById('laporanPaketChart'),{type:'doughnut',data:{labels:pkNames.length?pkNames:['Belum ada'],datasets:[{data:pkVals.length?pkVals:[1],backgroundColor:['#2563eb','#10b981','#f59e0b','#ef4444','#8b5cf6'],borderWidth:0}]},options:{responsive:true,plugins:{legend:{position:'bottom'}}}});

  document.getElementById('laporanBody').innerHTML=filtered.sort((a,b)=>new Date(b.tgl)-new Date(a.tgl)).map(t=>{
    const c=custs.find(c=>c.id===t.custId);const p=pks.find(p=>p.id===t.paketId);
    return `<tr><td>${t.tgl}</td><td>${c?c.nama:'–'}</td><td>${p?p.nama:'–'}</td><td>${fmtRupiah(t.harga)}</td><td>${fmtRupiah(t.hpp)}</td><td style="color:var(--success);font-weight:600;">${fmtRupiah(t.profit)}</td><td><span class="badge-custom ${t.statusBayar==='lunas'?'badge-info':'badge-warning'}">${t.statusBayar}</span></td></tr>`;
  }).join('')||'<tr><td colspan="7" class="text-center text-muted py-3">Tidak ada data</td></tr>';
}

function exportLaporan() {
  const trxs=DB.transaksis();const custs=DB.customers();const pks=DB.pakets();
  let csv='Tanggal,Customer,Paket,Harga Jual,HPP,Profit,Status Bayar\n';
  trxs.forEach(t=>{
    const c=custs.find(c=>c.id===t.custId);const p=pks.find(p=>p.id===t.paketId);
    csv+=`${t.tgl},"${c?c.nama:'?'}","${p?p.nama:'?'}",${t.harga},${t.hpp},${t.profit},${t.statusBayar}\n`;
  });
  const blob=new Blob([csv],{type:'text/csv'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');a.href=url;a.download='laporan_subflow.csv';a.click();
  showToast('Export CSV berhasil!');
}

